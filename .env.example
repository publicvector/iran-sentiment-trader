# LLM
OPENAI_API_KEY=your_openai_key_here

# Coinbase Advanced Trade API (for spot trading)
# Get keys from: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret

# Deribit (for BTC options trading)
# Get keys from: https://www.deribit.com/account
# Create API keys in your account settings
DERIBIT_CLIENT_ID=your_deribit_client_id
DERIBIT_CLIENT_SECRET=your_deribit_client_secret

# Twitter/X API v2 (for fetching posts)
# Get from https://developer.twitter.com/en/portal/dashboard
# Create a project with "Read" permissions, then create a Bearer Token
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Optional overrides
# OPENAI_MODEL=gpt-4o-mini
# POSITION_SIZE_USD=100
# POSITION_HOLD_SECONDS=300
# POLL_INTERVAL_SECONDS=60