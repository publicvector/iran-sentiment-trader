# LLM
OPENAI_API_KEY=your_openai_key_here

# Coinbase Advanced Trade API (for spot trading)
# Get keys from: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret

# OKX (for BTC perpetuals and options - US-friendly)
# Get keys from: https://www.okx.com/account
# Create API keys in Account -> API
OKX_API_KEY=***
OKX_API_SECRET=your_okx_secret
OKX_PASSPHRASE=your_okx_passphrase

# Kraken Futures (for BTC perpetuals - US-friendly)
# Get keys from: https://futures.kraken.com/account/api
KRAKEN_API_KEY=your_kraken_key
KRAKEN_API_SECRET=your_kraken_secret

# Twitter/X API v2 (for fetching posts)
# Get from https://developer.twitter.com/en/portal/dashboard
# Create a project with "Read" permissions, then create a Bearer Token
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Kalshi (CFTC-regulated prediction markets - US legal)
# Get keys from: https://kalshi.com/account/api
# Generate RSA key pair, download private key PEM file
KALSHI_API_KEY=your_kalshi_api_key
KALSHI_PRIVATE_KEY_PATH=~/.kalshi/private_key.pem
KALSHI_DEMO=false
# For cloud deploy (Railway etc), paste the full PEM as one line with \n:
# KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# dYdX v4 (decentralized perpetuals - no KYC)
# Your Cosmos wallet mnemonic (24 words)
DYDX_MNEMONIC=your 24 word mnemonic phrase here
DYDX_TESTNET=true  # set to false for mainnet

# Optional overrides
# OPENAI_MODEL=gpt-4o-mini
# POSITION_SIZE_USD=100
# POSITION_HOLD_SECONDS=300
# POLL_INTERVAL_SECONDS=60